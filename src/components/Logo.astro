---
import Icon from './Icon.astro';
interface Props {
  class?: string;
  light?: boolean;
}
const { class: className = 'h-10 w-auto', light = false } = Astro.props;
const textColor = light ? 'text-white' : 'text-brand-900';
const subColor = light ? 'text-brand-100' : 'text-brand-500';
---

<span class={`inline-flex items-center gap-2.5 ${className}`}>
  <span
    class="grid aspect-square h-full place-items-center rounded-xl bg-brand-700 text-white shadow-sm"
  >
    <Icon name="wrench" size={22} />
  </span>
  <span class="flex flex-col leading-none">
    <span class={`font-display text-[1.05rem] font-extrabold tracking-tight ${textColor}`}>
      Taller Isidro Pons
    </span>
    <span class={`mt-0.5 text-[0.66rem] font-semibold uppercase tracking-[0.18em] ${subColor}`}>
      SPG · Desde 1925
    </span>
  </span>
</span>
