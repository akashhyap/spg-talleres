---
import { site } from '@data/site';

interface Props {
  name: string;
  description: string;
  url: string;
}
const { name, description, url } = Astro.props;
const baseUrl = Astro.site?.href.replace(/\/$/, '') ?? '';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name,
  description,
  serviceType: name,
  url: `${baseUrl}${url}`,
  provider: {
    '@type': 'AutoRepair',
    '@id': `${baseUrl}/#business`,
    name: `${site.brand} ${site.name}`,
  },
  areaServed: site.areaServed.map((n) => ({ '@type': 'City', name: n })),
  availableChannel: {
    '@type': 'ServiceChannel',
    servicePhone: site.phone,
    serviceUrl: `${baseUrl}/contacto`,
  },
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} is:inline />
