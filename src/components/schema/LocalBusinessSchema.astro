---
import { site } from '@data/site';

const dayMap: Record<string, string> = {
  Lunes: 'Monday',
  Martes: 'Tuesday',
  Miércoles: 'Wednesday',
  Jueves: 'Thursday',
  Viernes: 'Friday',
  Sábado: 'Saturday',
  Domingo: 'Sunday',
};

const baseUrl = Astro.site?.href.replace(/\/$/, '') ?? '';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'AutoRepair',
  '@id': `${baseUrl}/#business`,
  name: `${site.brand} ${site.name}`,
  alternateName: site.name,
  description: site.description,
  url: `${baseUrl}/`,
  telephone: site.phone,
  email: site.email,
  image: `${baseUrl}/og-image.jpg`,
  logo: `${baseUrl}/logo.svg`,
  foundingDate: String(site.foundedYear),
  priceRange: '€€',
  currenciesAccepted: 'EUR',
  paymentAccepted: site.payments.join(', '),
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    addressLocality: site.address.locality,
    addressRegion: site.address.region,
    postalCode: site.address.postalCode,
    addressCountry: site.address.country,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: site.geo.latitude,
    longitude: site.geo.longitude,
  },
  hasMap: site.googleMapsUrl,
  areaServed: site.areaServed.map((name) => ({ '@type': 'City', name })),
  openingHoursSpecification: site.openingHours.map((block) => ({
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: block.days.map((d) => dayMap[d]).filter(Boolean),
    opens: block.opens,
    closes: block.closes,
  })),
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: site.rating.value,
    reviewCount: site.rating.count,
    bestRating: 5,
    worstRating: 1,
  },
  sameAs: [site.social.facebook, site.googleMapsUrl],
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} is:inline />
