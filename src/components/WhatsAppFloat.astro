---
import { site } from '@data/site';
import Icon from './Icon.astro';
---

<a
  href={site.whatsappCta}
  target="_blank"
  rel="noopener"
  class="fixed bottom-5 right-5 z-40 inline-flex items-center gap-2 rounded-full bg-[#25D366] px-4 py-3.5 font-semibold text-white shadow-lg transition-transform hover:scale-105 focus-visible:scale-105"
  aria-label="Escríbenos por WhatsApp"
>
  <Icon name="whatsapp" size={26} />
  <span class="hidden text-sm sm:inline">WhatsApp</span>
</a>
