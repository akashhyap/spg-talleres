---
import { site } from '@data/site';
import Icon from './Icon.astro';

interface Props {
  title?: string;
  text?: string;
}
const {
  title = '¿Tu coche necesita una revisión?',
  text = 'Pide cita sin compromiso. Te atendemos por teléfono o WhatsApp y te damos presupuesto antes de empezar.',
} = Astro.props;
---

<section class="container-page my-20">
  <div class="relative overflow-hidden rounded-3xl bg-brand-800 px-6 py-12 text-center shadow-xl sm:px-12 sm:py-16">
    <div class="pointer-events-none absolute -right-16 -top-16 h-56 w-56 rounded-full bg-brand-700/60"></div>
    <div class="pointer-events-none absolute -bottom-20 -left-10 h-56 w-56 rounded-full bg-accent-500/10"></div>
    <div class="relative mx-auto max-w-2xl">
      <h2 class="text-balance text-3xl font-bold text-white sm:text-4xl">{title}</h2>
      <p class="mx-auto mt-4 max-w-xl text-pretty text-brand-100">{text}</p>
      <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a
          href={site.whatsappCta}
          target="_blank"
          rel="noopener"
          class="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-accent-500 px-6 py-3.5 font-semibold text-brand-950 shadow-sm transition-colors hover:bg-accent-400 sm:w-auto"
        >
          <Icon name="whatsapp" size={20} /> Pedir cita por WhatsApp
        </a>
        <a
          href={`tel:${site.phoneHref}`}
          class="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-white/10 px-6 py-3.5 font-semibold text-white ring-1 ring-inset ring-white/25 transition-colors hover:bg-white/20 sm:w-auto"
        >
          <Icon name="phone" size={20} /> {site.phone}
        </a>
      </div>
    </div>
  </div>
</section>
