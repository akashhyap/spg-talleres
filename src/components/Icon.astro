  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  role={title ? 'img' : undefined}
  aria-hidden={title ? undefined : 'true'}
  aria-label={title}
  set:html={(title ? `<title>${title}</title>` : '') + inner}
