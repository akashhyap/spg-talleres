{%- liquid
  assign left_heading      = section.settings.left_heading      | default: ''
  assign right_heading     = section.settings.right_heading     | default: ''
  assign left_heading_tag  = section.settings.left_heading_tag  | default: 'h2'
  assign right_heading_tag = section.settings.right_heading_tag | default: 'h2'
  if left_heading != blank
    assign section_label = left_heading | strip_html
  else
    assign section_label = 'sections.dual_image_banner.aria_label' | t
  endif

  if section.settings.left_image != blank
    assign left_aspect = section.settings.left_image.aspect_ratio | default: 1.0
  else
    assign left_aspect = 1.0
  endif

  case section.settings.mobile_panel_aspect
    when 'wide'
      assign mobile_aspect = '16 / 9'
    when 'landscape'
      assign mobile_aspect = '4 / 3'
    when 'square'
      assign mobile_aspect = '1 / 1'
    when 'tall'
      assign mobile_aspect = '3 / 4'
    when 'very-tall'
      assign mobile_aspect = '2 / 3'
    else
      assign mobile_aspect = '4 / 5'
  endcase

  case section.settings.title_font
    when 'bebas'
      assign title_font_value = "'Bebas Neue', sans-serif"
    when 'hanken'
      assign title_font_value = "'Hanken Grotesk', sans-serif"
    else
      assign title_font_value = "inherit"
  endcase
-%}

<section
  class="dual-banner-wrapper"
  role="region"
  aria-label="{{ section_label | escape }}"
  style="--panel-gap: {{ section.settings.panel_gap }}px; --left-img-aspect: {{ left_aspect }}; --mobile-aspect: {{ mobile_aspect }}; --title-font-family: {{ title_font_value }};"
>
  <div class="dual-banner dual-banner--{{ section.settings.banner_height }}">

    {%- comment -%}============================
      LEFT PANEL
    =============================={%- endcomment -%}
    <div
      class="dual-banner__panel dual-banner__panel--{{ section.settings.left_text_alignment }} dual-banner__panel--vpos-{{ section.settings.left_content_vpos }}"
      style="--text-color: {{ section.settings.left_text_color }}; --img-position: {{ section.settings.left_image_position }}; --heading-font: {{ section.settings.left_heading_font_size }}px; --heading-font-mobile: {{ section.settings.left_heading_font_size_mobile }}px; --heading-bottom: {{ section.settings.left_heading_bottom_margin }}px; --heading-bottom-mobile: {{ section.settings.left_heading_bottom_margin_mobile }}px; --subtext-font: {{ section.settings.left_subtext_font_size }}px; --subtext-font-mobile: {{ section.settings.left_subtext_font_size_mobile }}px; --btn-font: {{ section.settings.left_button_font_size }}px; --btn-font-mobile: {{ section.settings.left_button_font_size_mobile }}px;"
    >
      {%- if section.settings.left_image != blank -%}
        <div class="dual-banner__media">

          {%- if section.settings.left_image_mobile != blank -%}
            {%- comment -%}
              Single <picture>: the browser downloads ONLY the source matching
              the viewport, so mobile never fetches the desktop hero (and vice
              versa). Eliminates the duplicate hero download and keeps
              fetchpriority on the image that actually renders.
            {%- endcomment -%}
            <picture>
              <source
                media="(max-width: 767px)"
                srcset="
                  {{ section.settings.left_image_mobile | image_url: width: 400 }} 400w,
                  {{ section.settings.left_image_mobile | image_url: width: 800 }} 800w
                "
                sizes="100vw"
              >
              <img
                src="{{ section.settings.left_image | image_url: width: 1600 }}"
                srcset="
                  {{ section.settings.left_image | image_url: width: 400  }} 400w,
                  {{ section.settings.left_image | image_url: width: 800  }} 800w,
                  {{ section.settings.left_image | image_url: width: 1200 }} 1200w,
                  {{ section.settings.left_image | image_url: width: 1600 }} 1600w,
                  {{ section.settings.left_image | image_url: width: 1920 }} 1920w
                "
                sizes="(min-width: 768px) 50vw, 100vw"
                alt="{{ section.settings.left_image.alt | default: left_heading | strip_html | escape }}"
                width="{{ section.settings.left_image.width }}"
                height="{{ section.settings.left_image.height }}"
                loading="eager"
                fetchpriority="high"
                decoding="async"
                class="dual-banner__img"
              >
            </picture>
          {%- else -%}
            {%- comment -%}No separate mobile image — single image used at all breakpoints.{%- endcomment -%}
            <img
              src="{{ section.settings.left_image | image_url: width: 1600 }}"
              srcset="
                {{ section.settings.left_image | image_url: width: 400  }} 400w,
                {{ section.settings.left_image | image_url: width: 800  }} 800w,
                {{ section.settings.left_image | image_url: width: 1200 }} 1200w,
                {{ section.settings.left_image | image_url: width: 1600 }} 1600w,
                {{ section.settings.left_image | image_url: width: 1920 }} 1920w
              "
              sizes="(min-width: 768px) 50vw, 100vw"
              alt="{{ section.settings.left_image.alt | default: left_heading | strip_html | escape }}"
              width="{{ section.settings.left_image.width }}"
              height="{{ section.settings.left_image.height }}"
              loading="eager"
              fetchpriority="high"
              decoding="async"
              class="dual-banner__img"
            >
          {%- endif -%}

          <div class="dual-banner__overlay" aria-hidden="true" style="opacity: {{ section.settings.left_overlay_opacity | divided_by: 100.0 }};"></div>
        </div>
      {%- endif -%}

      <div class="dual-banner__inner">
        <div class="dual-banner__content">
          {%- if left_heading != blank -%}
            <{{ left_heading_tag }} class="dual-banner__heading">{{ left_heading }}</{{ left_heading_tag }}>
          {%- endif -%}
          {%- if section.settings.left_text != blank -%}
            <p class="dual-banner__subtext">{{ section.settings.left_text }}</p>
          {%- endif -%}
          {%- if section.settings.left_btn1_label != blank -%}
            <div class="dual-banner__buttons">
              <a
                href="{{ section.settings.left_btn1_link | default: '#' }}"
                class="btn btn--{{ section.settings.left_btn1_style }}"
                {%- if left_heading != blank -%}
                  aria-label="{{ section.settings.left_btn1_label }} – {{ left_heading | strip_html | escape }}"
                {%- endif -%}
              >
                {{- section.settings.left_btn1_label -}}
              </a>
              {%- if section.settings.left_btn2_label != blank -%}
                <a
                  href="{{ section.settings.left_btn2_link | default: '#' }}"
                  class="btn btn--{{ section.settings.left_btn2_style }}"
                  {%- if left_heading != blank -%}
                    aria-label="{{ section.settings.left_btn2_label }} – {{ left_heading | strip_html | escape }}"
                  {%- endif -%}
                >
                  {{- section.settings.left_btn2_label -}}
                </a>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>

    {%- comment -%}============================
      RIGHT PANEL
    =============================={%- endcomment -%}
    <div
      class="dual-banner__panel dual-banner__panel--{{ section.settings.right_text_alignment }} dual-banner__panel--vpos-{{ section.settings.right_content_vpos }}"
      style="--text-color: {{ section.settings.right_text_color }}; --img-position: {{ section.settings.right_image_position }}; --heading-font: {{ section.settings.right_heading_font_size }}px; --heading-font-mobile: {{ section.settings.right_heading_font_size_mobile }}px; --heading-bottom: {{ section.settings.right_heading_bottom_margin }}px; --heading-bottom-mobile: {{ section.settings.right_heading_bottom_margin_mobile }}px; --subtext-font: {{ section.settings.right_subtext_font_size }}px; --subtext-font-mobile: {{ section.settings.right_subtext_font_size_mobile }}px; --btn-font: {{ section.settings.right_button_font_size }}px; --btn-font-mobile: {{ section.settings.right_button_font_size_mobile }}px;"
    >
      {%- if section.settings.right_image != blank -%}
        <div class="dual-banner__media">

          {%- if section.settings.right_image_mobile != blank -%}
            {%- comment -%}
              Single <picture>: the browser downloads ONLY the source matching
              the viewport, so mobile never fetches the desktop hero (and vice
              versa). Eliminates the duplicate hero download and keeps
              fetchpriority on the image that actually renders.
            {%- endcomment -%}
            <picture>
              <source
                media="(max-width: 767px)"
                srcset="
                  {{ section.settings.right_image_mobile | image_url: width: 400 }} 400w,
                  {{ section.settings.right_image_mobile | image_url: width: 800 }} 800w
                "
                sizes="100vw"
              >
              <img
                src="{{ section.settings.right_image | image_url: width: 1600 }}"
                srcset="
                  {{ section.settings.right_image | image_url: width: 400  }} 400w,
                  {{ section.settings.right_image | image_url: width: 800  }} 800w,
                  {{ section.settings.right_image | image_url: width: 1200 }} 1200w,
                  {{ section.settings.right_image | image_url: width: 1600 }} 1600w,
                  {{ section.settings.right_image | image_url: width: 1920 }} 1920w
                "
                sizes="(min-width: 768px) 50vw, 100vw"
                alt="{{ section.settings.right_image.alt | default: right_heading | strip_html | escape }}"
                width="{{ section.settings.right_image.width }}"
                height="{{ section.settings.right_image.height }}"
                loading="eager"
                fetchpriority="high"
                decoding="async"
                class="dual-banner__img"
              >
            </picture>
          {%- else -%}
            <img
              src="{{ section.settings.right_image | image_url: width: 1600 }}"
              srcset="
                {{ section.settings.right_image | image_url: width: 400  }} 400w,
                {{ section.settings.right_image | image_url: width: 800  }} 800w,
                {{ section.settings.right_image | image_url: width: 1200 }} 1200w,
                {{ section.settings.right_image | image_url: width: 1600 }} 1600w,
                {{ section.settings.right_image | image_url: width: 1920 }} 1920w
              "
              sizes="(min-width: 768px) 50vw, 100vw"
              alt="{{ section.settings.right_image.alt | default: right_heading | strip_html | escape }}"
              width="{{ section.settings.right_image.width }}"
              height="{{ section.settings.right_image.height }}"
              loading="eager"
              fetchpriority="high"
              decoding="async"
              class="dual-banner__img"
            >
          {%- endif -%}

          <div class="dual-banner__overlay" aria-hidden="true" style="opacity: {{ section.settings.right_overlay_opacity | divided_by: 100.0 }};"></div>
        </div>
      {%- endif -%}

      <div class="dual-banner__inner">
        <div class="dual-banner__content">
          {%- if right_heading != blank -%}
            <{{ right_heading_tag }} class="dual-banner__heading">{{ right_heading }}</{{ right_heading_tag }}>
          {%- endif -%}
          {%- if section.settings.right_text != blank -%}
            <p class="dual-banner__subtext">{{ section.settings.right_text }}</p>
          {%- endif -%}
          {%- if section.settings.right_btn_label != blank -%}
            <div class="dual-banner__buttons">
              <a
                href="{{ section.settings.right_btn_link | default: '#' }}"
                class="btn btn--{{ section.settings.right_btn_style }}"
                {%- if right_heading != blank -%}
                  aria-label="{{ section.settings.right_btn_label }} – {{ right_heading | strip_html | escape }}"
                {%- endif -%}
              >
                {{- section.settings.right_btn_label -}}
              </a>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  /* ===========================================
     WRAPPER — max-width container with padding
     =========================================== */
  .dual-banner-wrapper {
    width: 100%;
    max-width: 1800px;
    margin-left: auto;
    margin-right: auto;
    padding: 0 2rem;
    box-sizing: border-box;
  }

  /* Tablet: reduce side padding */
  @media (max-width: 1024px) {
    .dual-banner-wrapper {
      padding: 0 1.25rem;
    }
  }

  /* Mobile: full-bleed, no side padding */
  @media (max-width: 767px) {
    .dual-banner-wrapper {
      padding: 0;
    }
  }

  /* ===========================================
     DUAL BANNER ROW — flex container
     =========================================== */
  .dual-banner {
    display: flex;
    flex-direction: row;
    gap: var(--panel-gap, 0px);
    width: 100%;
    overflow: hidden;
  }

  /* Stack on mobile */
  @media (max-width: 767px) {
    .dual-banner {
      flex-direction: column;
      gap: 4px;
    }
  }

  /* ===========================================
     PANEL — asymmetric split: left ~63%, right ~37%
     Mirrors the About You reference layout.
     =========================================== */
  .dual-banner__panel {
    position: relative;
    min-width: 0;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Left panel — wider dominant column */
  .dual-banner__panel:first-child {
    flex: 1.7 1 0;
  }

  /* Right panel — narrower accent column */
  .dual-banner__panel:last-child {
    flex: 1 1 0;
  }

  /* Tablet: ease the ratio slightly so right panel doesn't feel squeezed */
  @media (max-width: 1024px) and (min-width: 768px) {
    .dual-banner__panel:first-child { flex: 1.4 1 0; }
    .dual-banner__panel:last-child  { flex: 1 1 0;   }
  }

  /* Mobile: each panel full width, stacked vertically */
  @media (max-width: 767px) {
    .dual-banner__panel:first-child,
    .dual-banner__panel:last-child {
      flex: none;
      width: 100%;
    }
  }

  /* ===========================================
     MEDIA LAYER — absolute-fills the panel
     =========================================== */
  .dual-banner__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .dual-banner__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--img-position, top center);
    border-radius: 8px;
    display: block;
  }

  /* <picture> wrapper must fill the media layer so the img's height:100%
     resolves against a definite height (picture is display:inline by default). */
  .dual-banner__media picture {
    display: block;
    width: 100%;
    height: 100%;
  }

  @media (max-width: 767px) {
    .dual-banner__img {
      border-radius: 0;
    }
  }

  .dual-banner__overlay {
    position: absolute;
    inset: 0;
    background: #000000;
    z-index: 1;
  }

  /* ===========================================
     HEIGHT OPTIONS
     Both panels share the same height mode via
     the modifier class on .dual-banner.
     For auto height the left image aspect ratio
     drives both panels via --left-img-aspect.
     =========================================== */

  /* AUTO — driven by left image aspect ratio, capped at 80vh */
  .dual-banner--auto .dual-banner__panel {
    aspect-ratio: var(--left-img-aspect, 1);
    max-height: 80vh;
  }

  /* SMALL */
  .dual-banner--small .dual-banner__panel {
    aspect-ratio: 10 / 3;
  }

  /* MEDIUM */
  .dual-banner--medium .dual-banner__panel {
    aspect-ratio: 8 / 3;
  }

  /* LARGE */
  .dual-banner--large .dual-banner__panel {
    aspect-ratio: 6 / 3;
  }

  /* FULLSCREEN */
  .dual-banner--fullscreen .dual-banner__panel {
    min-height: calc(100vh - var(--header-height, 80px) - var(--announcement-height, 40px));
  }

  /*
     MOBILE — Banner Height is a desktop layout knob. On mobile the panels
     are always full-width and stacked, so they share a single portrait
     aspect (4:5) regardless of which height mode is selected. Fullscreen
     keeps its viewport-height behaviour.
  */
  @media (max-width: 767px) {
    .dual-banner--auto .dual-banner__panel,
    .dual-banner--small .dual-banner__panel,
    .dual-banner--medium .dual-banner__panel,
    .dual-banner--large .dual-banner__panel {
      aspect-ratio: var(--mobile-aspect, 4 / 5);
      max-height: 65vh;
    }

    .dual-banner--fullscreen .dual-banner__panel {
      min-height: calc(100vh - var(--header-height-mobile, 60px) - var(--announcement-height, 40px));
    }
  }

  /* ===========================================
     CONTENT LAYER
     =========================================== */
  .dual-banner__inner {
    position: relative;
    z-index: 2;
    width: 100%;
    padding: 2rem 2.5rem 4.5rem;
    display: flex;
    align-items: flex-end; /* content anchors toward bottom of panel by default */
    height: 100%;
  }

  /* Vertical content position variants */
  .dual-banner__panel--vpos-top    .dual-banner__inner { align-items: flex-start; padding-top: 4.5rem; padding-bottom: 2rem; }
  .dual-banner__panel--vpos-center .dual-banner__inner { align-items: center;     padding-top: 2rem;   padding-bottom: 2rem; }
  .dual-banner__panel--vpos-bottom .dual-banner__inner { align-items: flex-end;   padding-top: 2rem;   padding-bottom: 4.5rem; }

  /* Tablet */
  @media (max-width: 1024px) and (min-width: 768px) {
    .dual-banner__inner {
      padding: 2rem 2rem 3.5rem;
    }
  }

  /* Mobile */
  @media (max-width: 767px) {
    .dual-banner__inner {
      padding: 1.5rem 1.25rem 3rem;
    }
  }

  .dual-banner__content {
    width: 100%;
  }

  /* TEXT ALIGNMENT */
  .dual-banner__panel--left .dual-banner__content {
    text-align: left;
    margin-right: auto;
  }

  .dual-banner__panel--center .dual-banner__content {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
  }

  .dual-banner__panel--right .dual-banner__content {
    text-align: right;
    margin-left: auto;
  }

  /* ===========================================
     TYPOGRAPHY
     -------------------------------------------
     All sizing is driven by per-panel CSS vars set inline on the panel
     from the schema range sliders. Each typography element has separate
     desktop and mobile values, switched via the 767px breakpoint below.
     !important keeps these rules winning against any cached base.css rules.
     =========================================== */
  .dual-banner__heading {
    font-family: var(--title-font-family, 'Hanken Grotesk', sans-serif);
    font-size: var(--heading-font, 28px) !important;
    font-weight: 400;
    line-height: 1.15;
    margin: 0 0 var(--heading-bottom, 24px) 0 !important;
    color: var(--text-color, #ffffff);
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.3);
  }

  .dual-banner__subtext {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--subtext-font, 16px) !important;
    font-weight: 400;
    line-height: 1.6;
    margin: 0 0 1.5rem 0;
    color: var(--text-color, #ffffff);
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.3);
  }

  @media (max-width: 767px) {
    .dual-banner__heading {
      font-size: var(--heading-font-mobile, 22px) !important;
      margin-bottom: var(--heading-bottom-mobile, 16px) !important;
    }
    .dual-banner__subtext {
      font-size: var(--subtext-font-mobile, 15px) !important;
    }
  }

  /* ===========================================
     BUTTONS
     =========================================== */
  .dual-banner__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .dual-banner__panel--center .dual-banner__buttons {
    justify-content: center;
  }

  .dual-banner__panel--right .dual-banner__buttons {
    justify-content: flex-end;
  }

  /* Inherit btn styles from base theme; define here for self-containment.
     Font size is driven by per-panel CSS vars (--btn-font, --btn-font-mobile)
     set inline on the panel from the schema range sliders. Padding uses em
     so it scales proportionally with the chosen font size.
     !important keeps these rules winning against any cached base.css .btn rule. */
  .dual-banner .btn {
    display: inline-block;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--btn-font, 16px) !important;
    padding: 1em 2.5em !important;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-decoration: none;
    border-radius: 2px;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    cursor: pointer;
    border: 2px solid transparent;
    white-space: nowrap;
    line-height: 1.1;
  }

  @media (max-width: 767px) {
    .dual-banner .btn {
      font-size: var(--btn-font-mobile, 14px) !important;
    }
  }

  .dual-banner .btn--primary {
    background: #000000;
    color: #ffffff;
    border-color: #000000;
  }

  .dual-banner .btn--primary:hover {
    background: #333333;
    border-color: #333333;
  }

  .dual-banner .btn--secondary {
    background: transparent;
    color: var(--text-color, #ffffff);
    border-color: var(--text-color, #ffffff);
  }

  .dual-banner .btn--secondary:hover {
    background: var(--text-color, #ffffff);
    color: #000000;
  }

  .dual-banner .btn--white {
    background: #ffffff;
    color: #000000;
    border-color: #ffffff;
  }

  .dual-banner .btn--white:hover {
    background: #ebebeb;
    border-color: #ebebeb;
  }

  /* ===========================================
     RESPONSIVE VISIBILITY
     (mirrors image-banner.liquid conventions)
     =========================================== */
  .hidden-mobile  { display: block; }
  .hidden-desktop { display: none;  }

  @media (max-width: 767px) {
    .hidden-mobile  { display: none;  }
    .hidden-desktop { display: block; }
  }

  /* ===========================================
     MOBILE CONTENT CENTERING
     Regardless of the desktop alignment setting,
     content centres on mobile because the panel
     is full-width and centred reads cleaner.
     =========================================== */
  @media (max-width: 767px) {
    .dual-banner__panel--left .dual-banner__content,
    .dual-banner__panel--right .dual-banner__content {
      text-align: center;
      margin-left: auto;
      margin-right: auto;
    }
    .dual-banner__panel--left .dual-banner__buttons,
    .dual-banner__panel--right .dual-banner__buttons {
      justify-content: center;
    }
  }
</style>

{% schema %}
{
  "name": "Dual Image Banner",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "banner_height",
      "label": "Banner Height (desktop)",
      "info": "Controls the side-by-side panel proportions on desktop. Mobile uses its own setting below.",
      "options": [
        { "value": "auto",       "label": "Auto (Image Ratio, max 80vh)" },
        { "value": "small",      "label": "Small"      },
        { "value": "medium",     "label": "Medium"     },
        { "value": "large",      "label": "Large"      },
        { "value": "fullscreen", "label": "Full Screen" }
      ],
      "default": "auto"
    },
    {
      "type": "select",
      "id": "mobile_panel_aspect",
      "label": "Panel aspect (mobile)",
      "info": "Shape each panel takes when stacked on mobile. Independent of Banner Height.",
      "options": [
        { "value": "wide",       "label": "Wide (16:9)"          },
        { "value": "landscape",  "label": "Landscape (4:3)"      },
        { "value": "square",     "label": "Square (1:1)"         },
        { "value": "portrait",   "label": "Portrait (4:5)"       },
        { "value": "tall",       "label": "Tall portrait (3:4)"  },
        { "value": "very-tall",  "label": "Very tall (2:3)"      }
      ],
      "default": "portrait"
    },
    {
      "type": "range",
      "id": "panel_gap",
      "label": "Gap between panels",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "title_font",
      "label": "Title font",
      "info": "Bebas Neue is a display font (all caps look) — best for short, prominent headings.",
