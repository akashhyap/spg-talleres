---
import BaseLayout from '@layouts/BaseLayout.astro';
import Icon from '@components/Icon.astro';
import { site } from '@data/site';
---

<BaseLayout title="Página no encontrada" description="La página que buscas no existe. Vuelve al inicio o consulta nuestros servicios." noindex>
  <section class="container-page flex flex-col items-center py-24 text-center">
    <span class="grid h-16 w-16 place-items-center rounded-2xl bg-brand-50 text-brand-700">
      <Icon name="wrench" size={32} />
    </span>
    <p class="mt-6 font-display text-6xl font-extrabold text-brand-900">404</p>
    <h1 class="mt-2 text-[length:var(--text-h3)] font-bold text-brand-900">No hemos encontrado esta página</h1>
    <p class="mt-3 max-w-md text-slate-600">
      Es posible que el enlace haya cambiado o ya no exista. Puedes volver al inicio o ver nuestros servicios.
    </p>
    <div class="mt-8 flex flex-col gap-3 sm:flex-row">
      <a href="/" class="inline-flex items-center justify-center gap-2 rounded-xl bg-brand-600 px-6 py-3 font-semibold text-white hover:bg-brand-700">
        Volver al inicio
      </a>
      <a href="/servicios" class="inline-flex items-center justify-center gap-2 rounded-xl border border-brand-200 bg-white px-6 py-3 font-semibold text-brand-700 hover:bg-brand-50">
        Ver servicios
      </a>
      <a href={`tel:${site.phoneHref}`} class="inline-flex items-center justify-center gap-2 rounded-xl border border-brand-200 bg-white px-6 py-3 font-semibold text-brand-700 hover:bg-brand-50">
        <Icon name="phone" size={18} /> Llamar
      </a>
    </div>
  </section>
</BaseLayout>
