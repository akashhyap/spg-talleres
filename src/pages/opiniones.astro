---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/PageHeader.astro';
import StarRating from '@components/StarRating.astro';
import CTASection from '@components/CTASection.astro';
import Icon from '@components/Icon.astro';
import { site } from '@data/site';

const aspectos = [
  { icon: 'users', title: 'Trato cercano', text: 'Atención personalizada y honesta, explicando siempre qué necesita el coche.' },
  { icon: 'shield', title: 'Trabajo de calidad', text: 'Reparaciones bien hechas y con garantía de la red SPG.' },
  { icon: 'checkCircle', title: 'Transparencia', text: 'Presupuesto claro antes de empezar, sin sorpresas en la factura.' },
];
---

<BaseLayout
  title="Opiniones de nuestros clientes"
  description="Opiniones del Taller Isidro A. Pons en Palma: 4,3 de valoración media en Google con 37 reseñas. Descubre por qué nuestros clientes confían en nosotros."
>
  <PageHeader
    eyebrow="Opiniones"
    title="La confianza de nuestros clientes"
    lead="Nuestra mejor carta de presentación son las valoraciones reales de quienes ya han confiado en nosotros."
    breadcrumbs={[{ name: 'Opiniones', url: '/opiniones' }]}
  />

  <section class="container-page py-14 lg:py-16">
    <div class="mx-auto max-w-3xl rounded-3xl border border-slate-200 bg-brand-50/60 p-8 text-center shadow-sm sm:p-12">
      <p class="text-sm font-semibold uppercase tracking-wider text-brand-600">Valoración en Google</p>
      <div class="mt-3 flex flex-col items-center gap-3">
        <span class="font-display text-6xl font-extrabold text-brand-900">{site.rating.value}</span>
        <StarRating value={site.rating.value} size={28} />
        <p class="text-slate-600">Media basada en <strong class="text-brand-800">{site.rating.count} reseñas</strong> de clientes verificados</p>
      </div>
      <div class="mt-7 flex flex-col justify-center gap-3 sm:flex-row">
        <a href={site.googleMapsUrl} target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 rounded-xl bg-brand-600 px-6 py-3 font-semibold text-white hover:bg-brand-700">
          <Icon name="star" size={18} /> Leer todas las reseñas
        </a>
        <a href={site.googleMapsUrl} target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 rounded-xl border border-brand-200 bg-white px-6 py-3 font-semibold text-brand-700 hover:bg-white">
          Dejar tu opinión
        </a>
      </div>
    </div>

    <div class="mx-auto mt-12 max-w-4xl">
      <h2 class="text-center text-[length:var(--text-h3)] font-bold text-brand-900">Lo que más valoran de nosotros</h2>
      <div class="mt-8 grid gap-5 sm:grid-cols-3">
        {
          aspectos.map((a) => (
            <div class="rounded-2xl border border-slate-200 bg-white p-6 text-center shadow-sm">
              <span class="mx-auto grid h-12 w-12 place-items-center rounded-xl bg-brand-50 text-brand-700">
                <Icon name={a.icon} size={24} />
              </span>
              <h3 class="mt-4 text-lg font-semibold text-brand-900">{a.title}</h3>
              <p class="mt-2 text-[0.95rem] leading-relaxed text-slate-600">{a.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <CTASection
    title="¿Quieres comprobarlo tú mismo?"
    text="Trae tu coche y descubre por qué tantos conductores de Palma confían en nosotros desde hace años."
  />
</BaseLayout>
