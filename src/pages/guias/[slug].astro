---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/PageHeader.astro';
import CTASection from '@components/CTASection.astro';
import Icon from '@components/Icon.astro';
import { site } from '@data/site';

export const getStaticPaths = (async () => {
  const guias = await getCollection('guias');
  const services = await getCollection('services');
  return guias.map((guia) => ({
    params: { slug: guia.id },
    props: { guia, services },
  }));
}) satisfies GetStaticPaths;

const { guia, services } = Astro.props;
const { Content } = await render(guia);

const related = guia.data.relatedServices
  .map((slug) => services.find((s) => s.id === slug))
  .filter((s): s is (typeof services)[number] => Boolean(s));

const baseUrl = Astro.site?.href.replace(/\/$/, '') ?? '';
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: guia.data.title,
  description: guia.data.description,
  datePublished: guia.data.publishDate.toISOString(),
  author: { '@type': 'Organization', name: `${site.brand} ${site.name}` },
  publisher: { '@type': 'Organization', name: `${site.brand} ${site.name}`, logo: { '@type': 'ImageObject', url: `${baseUrl}/logo.svg` } },
  mainEntityOfPage: `${baseUrl}/guias/${guia.id}`,
};
const fmtDate = (d: Date) => d.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={guia.data.title} description={guia.data.description}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(articleSchema)} is:inline />

  <PageHeader
    eyebrow={fmtDate(guia.data.publishDate)}
    title={guia.data.title}
    lead={guia.data.summary}
    breadcrumbs={[
      { name: 'Guías', url: '/guias' },
      { name: guia.data.title, url: `/guias/${guia.id}` },
    ]}
  />

  <div class="container-page grid gap-12 py-14 lg:grid-cols-[1fr_18rem] lg:gap-16">
    <article class="prose-content">
      <Content />
    </article>

    {
      related.length > 0 && (
        <aside class="lg:sticky lg:top-24 lg:self-start">
          <nav aria-label="Servicios relacionados" class="rounded-2xl border border-slate-200 bg-brand-50/60 p-6">
            <h2 class="text-lg font-bold text-brand-900">Servicios relacionados</h2>
            <ul class="mt-4 space-y-1">
              {related.map((r) => (
                <li>
                  <a href={`/servicios/${r.id}`} class="flex items-center gap-2.5 rounded-lg px-3 py-2.5 text-sm font-medium text-slate-700 transition-colors hover:bg-white hover:text-brand-800">
                    <Icon name={r.data.icon} size={18} class="text-brand-600" />
                    {r.data.shortTitle}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </aside>
      )
    }
  </div>

  <CTASection />
</BaseLayout>
