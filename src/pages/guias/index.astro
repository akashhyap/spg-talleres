---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/PageHeader.astro';
import CTASection from '@components/CTASection.astro';
import Icon from '@components/Icon.astro';

const guias = (await getCollection('guias')).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);
const fmtDate = (d: Date) => d.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  title="Guías y consejos para el cuidado de tu coche"
  description="Guías prácticas del Taller Isidro A. Pons: mantenimiento, frenos, ITV, correa de distribución y más consejos para cuidar tu coche en Palma."
>
  <PageHeader
    eyebrow="Guías del taller"
    title="Consejos prácticos para cuidar tu coche"
    lead="Resolvemos las dudas más habituales sobre el mantenimiento y la reparación del automóvil, con la experiencia de un taller con casi un siglo de historia."
    breadcrumbs={[{ name: 'Guías', url: '/guias' }]}
  />

  <section class="container-page py-14 lg:py-16">
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        guias.map((g) => (
          <article class="flex flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition-all hover:-translate-y-1 hover:shadow-md">
            <time datetime={g.data.publishDate.toISOString()} class="text-xs font-semibold uppercase tracking-wide text-brand-600">
              {fmtDate(g.data.publishDate)}
            </time>
            <h2 class="mt-3 text-lg font-semibold text-brand-900">
              <a href={`/guias/${g.id}`} class="hover:text-brand-700">{g.data.title}</a>
            </h2>
            <p class="mt-2 flex-1 text-[0.95rem] leading-relaxed text-slate-600">{g.data.summary}</p>
            <a href={`/guias/${g.id}`} class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-700 hover:text-brand-900">
              Leer guía <Icon name="arrowRight" size={16} />
            </a>
          </article>
        ))
      }
    </div>
  </section>

  <CTASection />
</BaseLayout>
